# WhatsApp MVP — environment variables
# Copy this file to .env and adjust for local development.
#
# In Docker Compose mode, DATABASE_URL and REDIS_URL are set by docker-compose.yml
# and typically don't need to be in .env. APP_PORT controls the HOST port mapping.

# PostgreSQL connection string (async driver)
# Compose default: postgresql+asyncpg://whatsapp:***@db:5432/whatsapp
DATABASE_URL=

# Redis connection string (dedup cache)
# Compose default: redis://redis:6379/0
REDIS_URL=

# Host port for Docker Compose (container always listens on 8000)
# Default: 8010
APP_PORT=
