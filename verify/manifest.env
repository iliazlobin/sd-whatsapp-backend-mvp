# WhatsApp MVP — e2e acceptance contract
# Sourced by the host e2e-verify loop (set -a; . manifest.env).
# Defines how to stand the system up, assert its functional requirements,
# and tear it down. Every value containing spaces is single-quoted so
# sourcing preserves it as a single token.

MODE=compose

# App port on the host (overridable by e2e-verify).
PORT=8021

# Board name for kanban fix cards.
BOARD=sd-whatsapp-backend-mvp-v2026-07-01-1

# Lifecycle commands — may use $PORT (expanded at eval time).
UP='APP_PORT=$PORT docker compose up -d --build'
DOWN='APP_PORT=$PORT docker compose down --volumes --remove-orphans'
READY='curl -sf http://localhost:$PORT/healthz'
LOGS='docker compose logs app --tail=50'

# Test dependencies (space-separated package names; pip-installed into verify/.venv).
# Black-box client only — NOT the app's own deps.
TEST_DEPS='httpx pytest'

# Acceptance suite — $PY points at verify/.venv/bin/python.
ACCEPTANCE='API_BASE_URL="http://localhost:$PORT" "$PY" -m pytest verify/acceptance -q'
